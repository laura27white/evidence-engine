{
  "name": "@tp/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Design tokens, primitives, motion, wordmark, and Storybook catalogue for Project Trueplan.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./tokens/index.ts",
    "./motion": "./src/motion/index.ts",
    "./brand": "./src/brand/index.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tokens/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "stylelint": "stylelint \"src/**/*.{css,tsx}\" \"tokens/**/*.ts\" --allow-empty-input",
    "chromatic": "chromatic --exit-zero-on-changes --skip='main'"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "0.453.0",
    "motion": "12.38.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3.2.2",
    "@storybook/addon-a11y": "8.3.5",
    "@storybook/addon-essentials": "8.3.5",
    "@storybook/blocks": "8.3.5",
    "@storybook/react": "8.3.5",
    "@storybook/react-vite": "8.3.5",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/wcag-contrast": "3.0.3",
    "axe-core": "4.10.0",
    "chromatic": "11.12.5",
    "stylelint": "16.10.0",
    "stylelint-config-standard": "36.0.1",
    "wcag-contrast": "3.0.0"
  }
}
