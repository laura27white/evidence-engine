{
  "name": "@tp/db",
  "version": "0.1.0",
  "private": true,
  "description": "Supabase schema, migrations, generated TypeScript types, and typed client factories for Project Trueplan.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./types/database.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"__tests__/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "build": "tsc",
    "import:hpo": "tsx scripts/import-hpo.ts",
    "seed:drift": "tsx scripts/seed-drift-measurements.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.45.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "tsx": "4.19.1",
    "xlsx": "0.18.5"
  }
}
