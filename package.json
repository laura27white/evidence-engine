{
  "name": "project-trueplan",
  "version": "0.1.0",
  "private": true,
  "description": "Project Trueplan: forecast-driven early warning system for project assumption drift. MPA Challenge 5 hackathon entry.",
  "author": "Laura White",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter @tp/web dev",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint && pnpm lint:emdash",
    "lint:emdash": "node scripts/check-no-emdash.mjs",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --ignore-path .gitignore",
    "prepare": "husky",
    "storybook": "pnpm --filter @tp/design-system storybook",
    "storybook:build": "pnpm --filter @tp/design-system build-storybook",
    "playwright": "pnpm --filter @tp/web playwright",
    "playwright:install": "pnpm --filter @tp/web exec playwright install --with-deps chromium",
    "db:import-hpo": "pnpm --filter @tp/db import:hpo",
    "db:seed-drift": "pnpm --filter @tp/db seed:drift",
    "db:gen-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema evidence_engine"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.3.5",
    "@storybook/addon-essentials": "8.3.5",
    "@storybook/react": "8.3.5",
    "@storybook/react-vite": "8.3.5",
    "@types/node": "20.14.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "4.3.2",
    "@vitest/coverage-v8": "2.1.1",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-react": "7.37.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "husky": "9.1.6",
    "jsdom": "25.0.1",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "8.3.5",
    "typescript": "5.5.4",
    "vite": "5.4.8",
    "vitest": "2.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
